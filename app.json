{
  "name": "DarkX-Ultra",
  "description": "Multi-device WhatsApp Bot — DarkX-Ultra",
  "repository": "https://github.com/darkxxweb-debug/DARKX-XMD",
  "logo": "https://files.catbox.moe/pc5uec.png",
  "keywords": ["bot", "whatsapp", "baileys", "darkx-ultra", "mongodb"],
  "env": {
    "MONGODB_URI": {
      "description": "MongoDB connection string used to store WhatsApp session credentials",
      "required": true
    },
    "ADMIN_PASSWORD": {
      "description": "Password for the web dashboard's Admin panel",
      "value": "admin123",
      "required": false
    },
    "PORT": {
      "description": "Port the web dashboard listens on",
      "value": "3000",
      "required": false
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  }
}
